# TLS/SSL Configuration
# Set to 0 to disable certificate verification (development only)
# Remove or set to 1 for production
NODE_TLS_REJECT_UNAUTHORIZED=0

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_WS_URL=ws://localhost:8000

# Demo Mode (for testing UI without backend)
# Set to true to use demo data and skip API calls
EXPO_PUBLIC_DEMO_MODE=false
EXPO_PUBLIC_DEMO_USER_ID=6

# Camera Configuration
EXPO_PUBLIC_CAMERA_ID=your-camera-id
